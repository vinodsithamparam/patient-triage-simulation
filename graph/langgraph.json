{
    "dependencies": [
        "."
    ],
    "graphs": {
        "triage": "./triage_graph.py:app"
    },
    "webhooks": {
        "url": {
            "require_https": true
        }
    },
    "http": {
        "cors": {
            "allow_methods": [
                "GET",
                "POST",
                "PUT",
                "DELETE",
                "OPTIONS"
            ],
            "allow_headers": [
                "*"
            ],
            "allow_credentials": true
        }
    }
}